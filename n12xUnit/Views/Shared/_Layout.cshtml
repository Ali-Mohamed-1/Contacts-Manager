<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@ViewBag.Title</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/StyleSheet.css" />
</head>
@{
    var actionName = ViewContext.RouteData.Values["action"]?.ToString() ?? string.Empty;
}
<body>
    <div class="layout-shell">
        <header class="navbar">
            <div class="brand-block">
                <div class="logo-mark">cm</div>
                <div>
                    <p class="brand-name">Contacts Manager</p>
                </div>
            </div>
            <nav class="nav-links">
                <a asp-controller="Persons"
                   asp-action="Index"
                   class="nav-link @(actionName == "Index" ? "nav-link-active" : string.Empty)">
                    Persons
                </a>
                <a asp-controller="Persons"
                   asp-action="Add"
                   class="nav-link @((actionName == "Add") ? "nav-link-active" : string.Empty)">
                    Add person
                </a>
                <a asp-controller="Account" asp-action="Register" class="nav-link">Register</a>
                <a asp-controller="Account" asp-action="Login" class="nav-link">Login</a>
            </nav>
        </header>

        <main class="page-content">
            @RenderBody()
        </main>
    </div>
    @RenderSection("Scripts", required: false)
</body>
</html>
