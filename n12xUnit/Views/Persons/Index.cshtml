@model IEnumerable<PersonResponse>
@{
    ViewBag.Title = "Persons";
    var persons = Model ?? Array.Empty<PersonResponse>();
    bool hasRecords = persons.Any();
    var searchFields = ViewBag.SearchFields as IEnumerable<KeyValuePair<string, string>> ?? Array.Empty<KeyValuePair<string, string>>();
    string searchBy = ViewBag.SearchBy ?? string.Empty;
    string searchString = ViewBag.SearchString ?? string.Empty;
    string sortBy = ViewBag.SortBy ?? string.Empty;
    bool isAscending = ViewBag.IsAscending is bool asc && asc;
}

<section class="page-header card-panel">
    <div>
        <h1 class="page-title">People overview</h1>
        <p class="subtitle">Search, sort and maintain everyone in a single clean workspace.</p>
    </div>
    <div class="header-actions">
        <a asp-controller="Persons" asp-action="Add" class="btn primary">
            <span>＋</span> New person
        </a>
    </div>
</section>

<form asp-controller="Persons" asp-action="Index" method="get" class="card-panel filter-form">
    <div class="filter-grid">
        <div class="filter-field">
            <label class="input-label" for="searchBy">Filter by</label>
            <select class="form-input" id="searchBy" name="searchBy" value="@searchBy">
                @foreach (var field in searchFields)
                {
                    if (field.Key == searchBy)
                    {
                        <option value="@field.Key" selected="selected">@field.Value</option>
                        continue;
                    }
                    <option value="@field.Key">@field.Value</option>
                }
            </select>
        </div>

        <div class="filter-field search-field">
            <label class="input-label" for="Search">Search text</label>
            <div class="search-input-row">
                <input name="searchString"
                       type="search"
                       id="Search"
                       class="form-input"
                       placeholder="Type a name, email, address…"
                       value="@searchString" />
                <button class="btn secondary" type="submit">Search</button>
                <a asp-controller="Persons" asp-action="Index" class="btn ghost">Clear</a>
            </div>
        </div>
    </div>
</form>

@if (!hasRecords)
{
    <div class="card-panel empty-state">
        <h3>No people found</h3>
        <p>Try adjusting your filters or add a new person to get started.</p>
        <a asp-controller="Persons" asp-action="Add" class="btn primary">Create the first person</a>
    </div>
}
else
{
    <div class="table-wrapper card-panel">
        <table class="data-table">
            <thead>
                <tr>
                    <th>
                        <a class="sort-link" href="~/persons/index?searchBy=@searchBy&searchString=@searchString&sortBy=Name&isAscending=@((sortBy == "Name" ? !isAscending : true))">
                            Name
                        </a>
                    </th>
                    <th>
                        <a class="sort-link" href="~/persons/index?searchBy=@searchBy&searchString=@searchString&sortBy=Email&isAscending=@((sortBy == "Email" ? !isAscending : true))">
                            Email
                        </a>
                    </th>
                    <th>
                        <a class="sort-link" href="~/persons/index?searchBy=@searchBy&searchString=@searchString&sortBy=DateOfBirth&isAscending=@((sortBy == "DateOfBirth" ? !isAscending : true))">
                            Date of birth
                        </a>
                    </th>
                    <th>
                        <a class="sort-link" href="~/persons/index?searchBy=@searchBy&searchString=@searchString&sortBy=Gender&isAscending=@((sortBy == "Gender" ? !isAscending : true))">
                            Gender
                        </a>
                    </th>
                    <th>
                        <a class="sort-link" href="~/persons/index?searchBy=@searchBy&searchString=@searchString&sortBy=Address&isAscending=@((sortBy == "Address" ? !isAscending : true))">
                            Address
                        </a>
                    </th>
                    <th>
                        <a class="sort-link" href="~/persons/index?searchBy=@searchBy&searchString=@searchString&sortBy=CountryName&isAscending=@((sortBy == "CountryName" ? !isAscending : true))">
                            Country
                        </a>
                    </th>
                    <th>
                        <a class="sort-link" href="~/persons/index?searchBy=@searchBy&searchString=@searchString&sortBy=ReceiveNewsLetters&isAscending=@((sortBy == "ReceiveNewsLetters" ? !isAscending : true))">
                            Newsletters
                        </a>
                    </th>
                    <th>Options</th>
                </tr>
            </thead>
            <tbody>
                @foreach (PersonResponse person in persons)
                {
                    <tr>
                        <td>@person.Name</td>
                        <td>@person.Email</td>
                        <td>@person.DateOfBirth.ToString("dd MMM yyyy")</td>
                        <td>@person.Gender</td>
                        <td>@person.Address</td>
                        <td>@person.CountryName</td>
                        <td>
                            <span class="badge @(person.ReceiveNewsLetters ? "badge-success" : "badge-muted")">
                                @(person.ReceiveNewsLetters ? "Subscribed" : "No")
                            </span>
                        </td>
                        <td>
                            <div class="table-actions">
                                <a asp-controller="Persons" asp-action="Edit" asp-route-personID="@person.PersonID" class="action-link">Edit</a>
                                <a asp-controller="Persons" asp-action="Delete" asp-route-personID="@person.PersonID" class="action-link danger">Delete</a>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}