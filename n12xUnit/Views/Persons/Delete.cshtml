@model PersonResponse
@{
    ViewBag.Title = "Delete Person";
}

<section class="page-header card-panel danger">
    <div>
        <h1 class="page-title">Delete person</h1>
        <p class="subtitle">This action cannot be undone. Please confirm the record you want to remove.</p>
    </div>
</section>

<div class="form-card card-panel">
    <form asp-controller="Persons" asp-action="Delete" method="post" class="responsive-form">
        <input type="hidden" asp-for="PersonID" />

        <div class="form-field">
            <label asp-for="Name" class="form-label"></label>
            <div>
                <input asp-for="Name" class="form-input" disabled />
            </div>
        </div>

        <div class="form-actions">
            <button class="btn danger" type="submit">Yes, delete</button>
            <a asp-controller="Persons" asp-action="Index" class="btn ghost">Cancel</a>
        </div>
    </form>
</div>