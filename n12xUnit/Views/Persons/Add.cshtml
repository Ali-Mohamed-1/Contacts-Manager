@model PersonAddRequest
@{
    ViewBag.Title = "Add Person";
}

<section class="page-header card-panel">
    <div>
        <h1 class="page-title">Add a new person</h1>
    </div>
</section>

<div class="form-card card-panel">
    <form asp-controller="Persons" asp-action="Create" method="post" class="responsive-form">
        <div class="form-field">
            <label asp-for="Name" class="form-label"></label>
            <div>
                <input asp-for="Name" class="form-input" />
                <span asp-validation-for="Name" class="validation-message"></span>
            </div>
        </div>

        <div class="form-field">
            <label asp-for="Email" class="form-label"></label>
            <div>
                <input asp-for="Email" type="email" class="form-input" />
                <span asp-validation-for="Email" class="validation-message"></span>
            </div>
        </div>

        <div class="form-field">
            <label asp-for="DateOfBirth" class="form-label">Date of birth</label>
            <div>
                <input asp-for="DateOfBirth" type="date" class="form-input" />
                <span asp-validation-for="DateOfBirth" class="validation-message"></span>
            </div>
        </div>

        <div class="form-field">
            <label asp-for="Gender" class="form-label"></label>
            <div class="option-chips">
                <label>
                    <input asp-for="Gender" type="radio" value="Male" />
                    <span>Male</span>
                </label>
                <label>
                    <input asp-for="Gender" type="radio" value="Female" />
                    <span>Female</span>
                </label>
                <span asp-validation-for="Gender" class="validation-message"></span>
            </div>
        </div>

        <div class="form-field">
            <label asp-for="CountryID" class="form-label">Country</label>
            <div>
                <select asp-for="CountryID" class="form-input"
                        asp-items="@(new SelectList(ViewBag.Countries, "CountryID", "CountryName"))">
                    <option value="">Please select</option>
                </select>
                <span asp-validation-for="CountryID" class="validation-message"></span>
            </div>
        </div>

        <div class="form-field">
            <label asp-for="Address" class="form-label"></label>
            <div>
                <textarea asp-for="Address" class="form-input" rows="3"></textarea>
                <span asp-validation-for="Address" class="validation-message"></span>
            </div>
        </div>

        <div class="form-field checkbox-field">
            <div>
                <label class="checkbox">
                    <input asp-for="ReceiveNewsLetters" type="checkbox" />
                    <span>Receive newsletters</span>
                </label>
                <span asp-validation-for="ReceiveNewsLetters" class="validation-message"></span>
            </div>
        </div>

        <div class="form-actions">
            <button class="btn primary" type="submit">Save person</button>
            <a asp-controller="Persons" asp-action="Index" class="btn ghost">Cancel</a>
        </div>

        @if (ViewBag.Errors != null)
        {
            <div class="form-errors">
                <ul>
                    @foreach (string error in ViewBag.Errors)
                    {
                        <li>@error</li>
                    }
                </ul>
            </div>
        }
    </form>
</div>

@section Scripts 
{

@* Client-side validation *@

@* 1. jquery *@
<script src="https://cdnjs.cloudflare.com/ajax/libs/jquery/3.6.0/jquery.min.js"
        asp-fallback-test="window.jQuery" asp-fallback-src="~\jquery.min.js"></script>

@* 2. jquery-validate *@
<script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-validate/1.21.0/jquery.validate.min.js"
        asp-fallback-test="window.jQuery.validator" asp-fallback-src="~\jquery.validate.min.js"></script>

@* 3. jquery-validation-unobtrusive *@
<script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-validation-unobtrusive/4.0.0/jquery.validate.unobtrusive.min.js"
        asp-fallback-test="window.jQuery.validator.unobstrusive" asp-fallback-src="~\jquery.validate.unobtrusive.min.js"></script>
}    